DATABASE_URL="postgresql://usuario:senha@host/database?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@host/database?sslmode=require"
JWT_SECRET="troque-por-uma-chave-grande-e-segura"
ENABLE_SEED="false"
CORS_ORIGIN="http://localhost:5173"
PORT=3000

FRONTEND_URL="http://localhost:5173"

# Configuração de envio de e-mail para recuperação de senha
# Exemplo Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="seu-email@gmail.com"
# SMTP_PASS="sua-senha-de-app"
# MAIL_FROM="PayGrid <seu-email@gmail.com>"

# Em desenvolvimento, se SMTP não estiver configurado,
# permite devolver o link no frontend como fallback de teste.
RESET_PASSWORD_DEBUG_LINK="true"
