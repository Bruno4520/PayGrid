generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                  Int             @id @default(autoincrement())
  nome                String
  email               String          @unique
  senha               String
  orcamentos          Orcamento[]
  contas              Conta[]
  cartoesCredito      CartaoCredito[]
  categorias          Categoria[]
  resultadosSimulacao Simulacao[]
}

model Conta {
  id          Int         @id @default(autoincrement())
  nome        String
  saldo       Float
  tipo        TipoConta
  numeroConta String
  agencia     String
  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId   Int
  transacoes  Transacao[]
}

enum TipoConta {
  CARTEIRA
  CONTA_CORRENTE
  POUPANCA
}

model Categoria {
  id          Int         @id @default(autoincrement())
  nome        String
  descricao   String?
  observacoes String?
  icone       String?
  cor         String?
  sistema     Boolean     @default(false)
  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId   Int
  orcamentos  Orcamento[]
  transacoes  Transacao[]

  @@unique([nome, usuarioId])
}

model Orcamento {
  id             Int       @id @default(autoincrement())
  valorPlanejado Float
  mes            Int
  ano            Int
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      Int
  categoria      Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  categoriaId    Int

  @@unique([usuarioId, categoriaId, mes, ano])
}

model Transacao {
  id              Int            @id @default(autoincrement())
  descricao       String
  valor           Float
  data            DateTime       @default(now())
  tipo            TipoTransacao
  formaPagamento  FormaPagamento
  observacoes     String?
  conta           Conta?         @relation(fields: [contaId], references: [id], onDelete: Cascade)
  contaId         Int?
  categoria       Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  categoriaId     Int?
  cartaoCredito   CartaoCredito? @relation(fields: [cartaoCreditoId], references: [id], onDelete: Cascade)
  cartaoCreditoId Int?
  parcelas        Parcela[]
  faturaPaga      Fatura?        @relation("PagamentoFatura")
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum FormaPagamento {
  DEBITO
  CREDITO
  PIX
  DINHEIRO
}

model CartaoCredito {
  id                  Int         @id @default(autoincrement())
  nome                String
  limite              Float
  diaFechamentoFatura Int
  diaVencimentoFatura Int
  ultimosDigitos      String
  usuario             Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId           Int
  faturas             Fatura[]
  transacoes          Transacao[]
}

model Fatura {
  id                   Int           @id @default(autoincrement())
  mes                  Int
  ano                  Int
  valorTotal           Float
  dataVencimento       DateTime
  estaPaga             Boolean       @default(false)
  cartaoCredito        CartaoCredito @relation(fields: [cartaoCreditoId], references: [id], onDelete: Cascade)
  cartaoCreditoId      Int
  parcelas             Parcela[]
  transacaoPagamento   Transacao?    @relation("PagamentoFatura", fields: [transacaoPagamentoId], references: [id], onDelete: SetNull)
  transacaoPagamentoId Int?          @unique

  @@unique([cartaoCreditoId, mes, ano])
}

model Parcela {
  id            Int       @id @default(autoincrement())
  numeroParcela Int
  valor         Float
  transacao     Transacao @relation(fields: [transacaoId], references: [id], onDelete: Cascade)
  transacaoId   Int
  fatura        Fatura    @relation(fields: [faturaId], references: [id], onDelete: Cascade)
  faturaId      Int

  @@unique([transacaoId, numeroParcela])
}

model Simulacao {
  id                Int      @id @default(autoincrement())
  nome              String
  valorInicial      Float
  aporteMensal      Float
  taxaMensal        Float
  periodoMensal     Int
  dataSimulacao     DateTime @default(now())
  valorFinalBruto   Float
  valorImposto      Float
  valorFinalLiquido Float
  totalInvestido    Float
  ganhoLiquido      Float
  usuario           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId         Int
}
